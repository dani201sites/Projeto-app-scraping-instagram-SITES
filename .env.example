# Copie este arquivo para .env e preencha com suas chaves reais.
# Nunca coloque senhas, tokens ou cookies pessoais do Instagram aqui.

# Google Search via Serper
SERPER_API_KEY=

# Instagram publico via Apify
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-profile-scraper
APIFY_MAX_PROFILES_PER_RUN=30
APIFY_MAX_TOTAL_CHARGE_USD=0.25

# Banco de dados Neon Postgres
DATABASE_URL=
NEON_PROJECT_ID=lingering-sunset-62223330
NEON_DATABASE_NAME=neondb

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=

# IA para gerar prompt do site
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
ENABLE_AI_PROMPT_GENERATION=false
MAX_AI_PROMPTS_PER_RUN=5
MAX_AI_IMAGES_PER_PROMPT=4
PUBLIC_APP_URL=

# Regras da ferramenta
MAX_PROFILES_PER_DAY=30
MIN_INSTAGRAM_FOLLOWERS=500
MAX_INSTAGRAM_FOLLOWERS=8000
RECENT_POST_DAYS=90
GOOGLE_SITE_SEARCH_PAGES=2

# Execucao
HOST=127.0.0.1
PORT=3000
DRY_RUN=true
LOG_LEVEL=info
